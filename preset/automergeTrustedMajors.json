{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Allowlist des major de confiance (opt-in explicite). Ajouter ici un package pour automerger son major.",
  "packageRules": [
    {
      "description": "Captive es-project-config",
      "matchSourceUrls": ["https://github.com/Captive-Studio/es-project-config"],
      "automerge": true
    },
    {
      "description": "npm majors de confiance",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "matchPackageNames": ["lint-staged", "uuid"],
      "automerge": true
    },
    {
      "description": "activestorage 7.x -> 8.x",
      "matchManagers": ["bundler"],
      "matchPackageNames": ["activestorage"],
      "matchCurrentVersion": "/^7\\./",
      "allowedVersions": ">=8.0.0 <9.0.0",
      "automerge": true
    },
    {
      "description": "solid_cable 3.x -> 4.x",
      "matchManagers": ["bundler"],
      "matchPackageNames": ["solid_cable"],
      "matchCurrentVersion": "/^3\\./",
      "allowedVersions": ">=4.0.0 <5.0.0",
      "automerge": true
    }
  ]
}
